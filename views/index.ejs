<%- include('partials/header') %>
<body>
  <%- include('partials/navbar') %>
  
  <div class="container">
    <hr>
    <h1>Perguntas</h1>
    <hr>
    <a href="/perguntar" class="btn btn-dark">Perguntar</a>
    <hr>

    <% perguntas.forEach(pergunta => { %>

      <div class="card">
        <div class="card-body">
          <h3><%= pergunta.titulo %></h3> <!--Exibo o título da pergunta (variável) em um p-->
        </div>
        <div class="card-footer">
          <button class="btn btn-dark">
            Responder
          </button>
        </div>
      </div>
      <br>
    <% }) %>
  </div>

</body>
<%- include('partials/footer') %>